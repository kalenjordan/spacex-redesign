<section class="newsletter full-width">
  <img class="newsletter__bg" src="{{ 'footer.png' | asset_url }}" alt="" loading="lazy">
  <div class="newsletter__scrim"></div>
  <div class="newsletter__inner">
    <div class="newsletter__copy">
      <span class="newsletter__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="5" width="18" height="14" rx="1.5"></rect>
          <path d="m3.5 6 8.5 6 8.5-6"></path>
        </svg>
      </span>
      <div>
        <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
        <p class="newsletter__text">{{ section.settings.text }}</p>
      </div>
    </div>

    {% form 'customer', class: 'newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {% if form.posted_successfully? %}
        <p class="newsletter__success">Thanks — you're on the list. 🚀</p>
      {% else %}
        <input
          type="email"
          name="contact[email]"
          class="newsletter__input"
          placeholder="{{ section.settings.placeholder }}"
          aria-label="Email"
          required
        >
        <button type="submit" class="btn btn--primary newsletter__submit">Subscribe</button>
      {% endif %}
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .newsletter {
    position: relative;
    display: grid;
    grid-template-columns: var(--content-grid);
    background: linear-gradient(180deg, #060912 0%, #0a1222 100%);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .newsletter__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    z-index: 0;
  }

  .newsletter__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(6, 9, 18, 0.55) 0%, rgba(6, 9, 18, 0.2) 100%);
  }

  .newsletter__inner {
    position: relative;
    z-index: 2;
    grid-column: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding: clamp(2rem, 5vw, 3.5rem) 0;
  }

  .newsletter__copy {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .newsletter__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    flex: 0 0 auto;
    border-radius: 6px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
  }

  .newsletter__icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  .newsletter__heading {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 0.3rem;
  }

  .newsletter__text {
    color: var(--color-muted);
    font-size: 0.88rem;
    margin: 0;
    max-width: 28rem;
  }

  .newsletter__form {
    display: flex;
    gap: 0.6rem;
    flex: 1 1 22rem;
    max-width: 32rem;
  }

  .newsletter__input {
    flex: 1;
    background: var(--color-background);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--style-border-radius-inputs);
    color: var(--color-foreground);
    padding: 0.95rem 1.1rem;
    font-size: 0.9rem;
  }

  .newsletter__input::placeholder {
    color: var(--color-muted);
  }

  .newsletter__input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .newsletter__submit {
    white-space: nowrap;
  }

  .newsletter__success {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  @media (max-width: 749px) {
    .newsletter__form {
      flex-basis: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the Loop" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Be the first to know about new drops, launch updates, and exclusive offers." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email" }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
