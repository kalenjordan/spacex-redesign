<section class="feature full-width">
  <div class="feature__panel">
    {% if section.settings.heading != blank %}
      <div class="feature__head">
        <h2 class="feature__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="feature__sub">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="feature__grid">
      {% for block in section.blocks %}
        {% assign th = block.settings.thumb_handle | strip %}
        {% assign thumb = all_products[th] %}
        <div class="callout" {{ block.shopify_attributes }}>
          {% if thumb != blank and thumb.featured_media %}
            <span class="callout__thumb"><img src="{{ thumb.featured_media | image_url: width: 220 }}" alt="" loading="lazy"></span>
          {% endif %}
          <h3 class="callout__title">{{ block.settings.title }}</h3>
          <p class="callout__desc">{{ block.settings.text }}</p>
          {% if block.settings.link_label != blank %}
            <a href="{{ block.settings.link }}" class="callout__link">{{ block.settings.link_label }} &rarr;</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .feature__panel {
    background:
      radial-gradient(80% 120% at 50% 0%, rgba(26, 109, 240, 0.1) 0%, transparent 60%),
      var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: clamp(1.75rem, 4vw, 3rem);
  }

  .feature__head {
    margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
  }

  .feature__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
  }

  .feature__sub {
    color: var(--color-muted);
    margin: 0.6rem 0 0;
    max-width: 36rem;
  }

  .feature__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  .callout {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: clamp(1rem, 2vw, 1.75rem);
    border-left: 1px solid var(--color-border);
  }

  .callout:first-child {
    border-left: none;
    padding-left: 0;
  }

  .callout__thumb {
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    margin-bottom: 1.1rem;
    background: radial-gradient(120% 120% at 50% 25%, #1a2233 0%, #0b0f18 100%);
    border: 1px solid var(--color-border);
  }

  .callout__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12%;
  }

  .callout__title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .callout__desc {
    color: var(--color-muted);
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0 0 0.9rem;
  }

  .callout__link {
    margin-top: auto;
    font-family: var(--font-heading);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .callout__link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .feature__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .callout {
      border-left: none;
      padding-left: 0;
    }
  }

  @media (max-width: 480px) {
    .feature__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature callouts",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "Callout",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Flight Ready" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Built for any environment." },
        { "type": "text", "id": "thumb_handle", "label": "Thumbnail product handle" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop Jackets" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Feature callouts",
      "blocks": [
        { "type": "callout" }, { "type": "callout" }, { "type": "callout" }, { "type": "callout" }
      ]
    }
  ]
}
{% endschema %}
