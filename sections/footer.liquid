<footer class="site-footer full-width">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a href="{{ routes.root_url }}" class="wordmark site-footer__wordmark">
          {{ section.settings.brand_text | default: shop.name }}
        </a>
        {% if section.settings.description != blank %}
          <p class="site-footer__desc">{{ section.settings.description }}</p>
        {% endif %}
        <div class="site-footer__socials">
          {% if section.settings.x_url != blank %}
            <a href="{{ section.settings.x_url }}" aria-label="X" class="social">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 3h3l-7 8 8.2 10h-6.4l-5-6.1L7 21H4l7.5-8.6L3.6 3H10l4.5 5.6L17.5 3Zm-1.1 16h1.7L8.1 4.8H6.3L16.4 19Z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" class="social">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {% endif %}
          {% if section.settings.youtube_url != blank %}
            <a href="{{ section.settings.youtube_url }}" aria-label="YouTube" class="social">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2.5" y="5.5" width="19" height="13" rx="3.5"/><path d="M10 9.2v5.6l5-2.8-5-2.8Z" fill="currentColor" stroke="none"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <div class="site-footer__menus">
        {% for block in section.blocks %}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4 class="footer-col__title">{{ block.settings.heading }}</h4>
            <ul class="footer-col__links">
              {% for link in block.settings.menu.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      <span class="site-footer__locale">
        {% if localization.country %}{{ localization.country.name }}{% endif %}
        ({{ cart.currency.iso_code }})
      </span>
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    display: grid;
    grid-template-columns: var(--content-grid);
    margin-top: clamp(3.5rem, 7vw, 6rem);
    border-top: 1px solid var(--color-border);
    background: var(--color-background);
  }

  .site-footer__inner {
    grid-column: 2;
    padding: clamp(2.5rem, 5vw, 4rem) 0 2rem;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1.4fr 2.6fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  .site-footer__wordmark {
    font-size: 1.4rem;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .site-footer__desc {
    color: var(--color-muted);
    font-size: 0.85rem;
    line-height: 1.5;
    max-width: 22rem;
    margin: 0 0 1.5rem;
  }

  .site-footer__socials {
    display: flex;
    gap: 0.85rem;
  }

  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .social:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .social svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .site-footer__menus {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .footer-col__title {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 1.1rem;
  }

  .footer-col__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer-col__links a {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.85rem;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }

  .footer-col__links a:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.78rem;
  }

  @media (max-width: 860px) {
    .site-footer__top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .site-footer__menus {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand wordmark", "default": "SPACEX" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "SpaceX designs, manufactures and launches the world's most advanced rockets and spacecraft." },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "x_url", "label": "X (Twitter) URL" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Shop" } },
        { "type": "menu", "settings": { "heading": "Customer Care" } },
        { "type": "menu", "settings": { "heading": "About SpaceX" } },
        { "type": "menu", "settings": { "heading": "Legal" } }
      ]
    }
  ]
}
{% endschema %}
