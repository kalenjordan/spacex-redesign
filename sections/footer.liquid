<footer class="site-footer full-width">
  <img class="site-footer__bg" src="{{ 'footer.png' | asset_url }}" alt="" loading="lazy">
  <div class="site-footer__scrim"></div>

  <div class="site-footer__inner">
    <div class="footer-newsletter">
      <div class="footer-newsletter__copy">
        <span class="footer-newsletter__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="5" width="18" height="14" rx="1.5"></rect>
            <path d="m3.5 6 8.5 6 8.5-6"></path>
          </svg>
        </span>
        <div>
          <h2 class="footer-newsletter__heading">{{ section.settings.newsletter_heading }}</h2>
          <p class="footer-newsletter__text">{{ section.settings.newsletter_text }}</p>
        </div>
      </div>

      {% form 'customer', class: 'footer-newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {% if form.posted_successfully? %}
          <p class="footer-newsletter__success">Thanks &mdash; you're on the list. &#128640;</p>
        {% else %}
          <input
            type="email"
            name="contact[email]"
            class="footer-newsletter__input"
            placeholder="{{ section.settings.newsletter_placeholder }}"
            aria-label="Email"
            required
          >
          <button type="submit" class="btn btn--primary">Subscribe</button>
        {% endif %}
      {% endform %}
    </div>

    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a href="{{ routes.root_url }}" class="wordmark site-footer__wordmark">
          {{ 'spacex-logo.svg' | inline_asset_content }}
        </a>
        {% if section.settings.description != blank %}
          <p class="site-footer__desc">{{ section.settings.description }}</p>
        {% endif %}
        <div class="site-footer__socials">
          {% if section.settings.x_url != blank %}
            <a href="{{ section.settings.x_url }}" aria-label="X" class="social">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 3h3l-7 8 8.2 10h-6.4l-5-6.1L7 21H4l7.5-8.6L3.6 3H10l4.5 5.6L17.5 3Zm-1.1 16h1.7L8.1 4.8H6.3L16.4 19Z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" class="social">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {% endif %}
          {% if section.settings.youtube_url != blank %}
            <a href="{{ section.settings.youtube_url }}" aria-label="YouTube" class="social">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2.5" y="5.5" width="19" height="13" rx="3.5"/><path d="M10 9.2v5.6l5-2.8-5-2.8Z" fill="currentColor" stroke="none"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <div class="site-footer__menus">
        <div class="footer-col">
          <h4 class="footer-col__title">Shop</h4>
          <ul class="footer-col__links">
            <li><a href="{{ routes.collections_url }}/men">Men</a></li>
            <li><a href="{{ routes.collections_url }}/women">Women</a></li>
            <li><a href="{{ routes.collections_url }}/kids">Kids</a></li>
            <li><a href="{{ routes.collections_url }}/accessories">Accessories</a></li>
            <li><a href="{{ routes.collections_url }}/flight-shirts">Flight Shirts</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-col__title">Customer Care</h4>
          <ul class="footer-col__links">
            <li><a href="#">Help Center</a></li>
            <li><a href="#">Shipping &amp; Returns</a></li>
            <li><a href="#">Sizing Guide</a></li>
            <li><a href="{{ routes.search_url }}">Contact Us</a></li>
            <li><a href="#">Gift Cards</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-col__title">About SpaceX</h4>
          <ul class="footer-col__links">
            <li><a href="https://www.spacex.com/mission/">Our Mission</a></li>
            <li><a href="https://www.spacex.com/careers/">Careers</a></li>
            <li><a href="https://www.spacex.com/updates/">Press</a></li>
            <li><a href="#">Sustainability</a></li>
            <li><a href="https://www.starlink.com/">Starlink</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-col__title">Legal</h4>
          <ul class="footer-col__links">
            <li><a href="{{ shop.terms_of_service.url | default: '#' }}">Terms of Use</a></li>
            <li><a href="{{ shop.privacy_policy.url | default: '#' }}">Privacy Policy</a></li>
            <li><a href="#">Cookies</a></li>
            <li><a href="#">Accessibility</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      <span class="site-footer__locale">
        {% if localization.country %}{{ localization.country.name }}{% endif %}
        ({{ cart.currency.iso_code }})
      </span>
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    position: relative;
    display: grid;
    grid-template-columns: var(--content-grid);
    margin-top: 0;
    background: var(--color-background);
    overflow: hidden;
  }

  .site-footer__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: clamp(320px, 40vw, 520px);
    object-fit: cover;
    object-position: center bottom;
    z-index: 0;
  }

  .site-footer__scrim {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: clamp(320px, 40vw, 520px);
    z-index: 1;
    background: linear-gradient(
      180deg,
      var(--color-background) 0%,
      rgba(5, 7, 13, 0.85) 14%,
      rgba(5, 7, 13, 0.2) 44%,
      rgba(5, 7, 13, 0.65) 74%,
      var(--color-background) 100%
    );
  }

  .site-footer__inner {
    position: relative;
    z-index: 2;
    grid-column: 2;
    padding: clamp(3rem, 5vw, 4.5rem) 0 2rem;
  }

  /* Newsletter row */
  .footer-newsletter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .footer-newsletter__copy {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .footer-newsletter__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    flex: 0 0 auto;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-card) 70%, transparent);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
    backdrop-filter: blur(6px);
  }

  .footer-newsletter__icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  .footer-newsletter__heading {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 0.3rem;
  }

  .footer-newsletter__text {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.88rem;
    margin: 0;
    max-width: 28rem;
  }

  .footer-newsletter__form {
    display: flex;
    gap: 0.6rem;
    flex: 1 1 22rem;
    max-width: 32rem;
  }

  .footer-newsletter__input {
    flex: 1;
    background: color-mix(in srgb, var(--color-background) 60%, transparent);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--style-border-radius-inputs);
    color: var(--color-foreground);
    padding: 0.95rem 1.1rem;
    font-size: 0.9rem;
    backdrop-filter: blur(6px);
  }

  .footer-newsletter__input::placeholder {
    color: var(--color-muted);
  }

  .footer-newsletter__input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .footer-newsletter__success {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1.4fr 2.6fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  .site-footer__wordmark {
    display: inline-block;
    margin-bottom: 1.25rem;
  }

  .site-footer__wordmark svg {
    height: 1.35rem;
    width: auto;
    display: block;
  }

  .site-footer__desc {
    color: var(--color-muted);
    font-size: 0.85rem;
    line-height: 1.5;
    max-width: 22rem;
    margin: 0 0 1.5rem;
  }

  .site-footer__socials {
    display: flex;
    gap: 0.85rem;
  }

  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .social:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .social svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .site-footer__menus {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .footer-col__title {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 1.1rem;
  }

  .footer-col__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer-col__links a {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.85rem;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }

  .footer-col__links a:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.78rem;
  }

  @media (max-width: 860px) {
    .footer-newsletter__form {
      flex-basis: 100%;
    }

    .site-footer__top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .site-footer__menus {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Stay in the Loop" },
    { "type": "textarea", "id": "newsletter_text", "label": "Newsletter text", "default": "Be the first to know about new drops, launch updates, and exclusive offers." },
    { "type": "text", "id": "newsletter_placeholder", "label": "Email placeholder", "default": "Enter your email" },
    { "type": "header", "content": "Brand" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "SpaceX designs, manufactures and launches the world's most advanced rockets and spacecraft." },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "x_url", "label": "X (Twitter) URL" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" }
  ]
}
{% endschema %}
