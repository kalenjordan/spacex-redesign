<section class="uniform full-width">
  <div class="uniform__grid">
    <div class="uniform__text">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow uniform__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="uniform__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}
        <p class="uniform__desc">{{ section.settings.text }}</p>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn btn--light uniform__btn">
          {{ section.settings.button_label }}
          <span class="btn__arrow">&rarr;</span>
        </a>
      {% endif %}

      <div class="uniform__list">
        {% for block in section.blocks %}
          <details class="uniform-item" {{ block.shopify_attributes }}>
            <summary class="uniform-item__summary">
              <span class="uniform-item__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <span class="uniform-item__label">{{ block.settings.label }}</span>
              <span class="uniform-item__plus" aria-hidden="true"></span>
            </summary>
            {% if block.settings.text != blank %}
              <div class="uniform-item__body">{{ block.settings.text }}</div>
            {% endif %}
          </details>
        {% endfor %}
      </div>
    </div>

    <div class="uniform__media">
      <img
        class="uniform__img"
        src="{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1600 }}{% else %}{{ 'uniform.jpg' | asset_url }}{% endif %}"
        alt="{{ section.settings.heading | escape }}"
        loading="lazy"
      >
    </div>
  </div>
</section>

{% stylesheet %}
  .uniform {
    display: grid;
    grid-template-columns: var(--content-grid);
    background: linear-gradient(90deg, #05070d 0%, #05070d 35%, #0a0d16 100%);
  }

  .uniform__grid {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    align-items: center;
  }

  .uniform__text {
    padding: clamp(2.5rem, 6vw, 5.5rem) clamp(2rem, 4vw, 4rem) clamp(2.5rem, 6vw, 5.5rem)
      max(var(--page-margin), calc((100vw - var(--page-width)) / 2 + var(--page-margin)));
  }

  .uniform__eyebrow {
    color: var(--color-foreground);
    opacity: 0.6;
    position: relative;
    padding-bottom: 1rem;
    margin-bottom: 1.75rem;
  }

  .uniform__eyebrow::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 2.5rem;
    height: 2px;
    background: var(--color-foreground);
    opacity: 0.4;
  }

  .uniform__heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    line-height: 0.95;
    margin: 0 0 1.5rem;
  }

  .uniform__desc {
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 26rem;
    margin: 0 0 2rem;
  }

  .btn--light {
    background: #fff;
    color: #05070d;
  }

  .btn--light:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  .uniform__btn {
    margin-bottom: 2.5rem;
  }

  /* Accordion list */
  .uniform__list {
    max-width: 28rem;
  }

  .uniform-item {
    border-top: 1px solid var(--color-border);
  }

  .uniform-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .uniform-item__summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.05rem 0;
    cursor: pointer;
    list-style: none;
  }

  .uniform-item__summary::-webkit-details-marker {
    display: none;
  }

  .uniform-item__num {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }

  .uniform-item__label {
    flex: 1;
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .uniform-item__plus {
    position: relative;
    width: 0.85rem;
    height: 0.85rem;
    flex: 0 0 auto;
  }

  .uniform-item__plus::before,
  .uniform-item__plus::after {
    content: '';
    position: absolute;
    background: var(--color-foreground);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .uniform-item__plus::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    transform: translateY(-50%);
  }

  .uniform-item__plus::after {
    left: 50%;
    top: 0;
    width: 1.5px;
    height: 100%;
    transform: translateX(-50%);
  }

  .uniform-item[open] .uniform-item__plus::after {
    opacity: 0;
    transform: translateX(-50%) rotate(90deg);
  }

  .uniform-item__body {
    padding: 0 0 1.2rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 24rem;
  }

  /* Image (numbered indicators are baked into the asset) */
  .uniform__media {
    position: relative;
    align-self: stretch;
  }

  .uniform__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @supports (aspect-ratio: 1) {
    .uniform__media {
      align-self: center;
    }

    .uniform__img {
      height: auto;
      aspect-ratio: 3 / 2;
    }
  }

  /* ---- Breakpoint 1: tablet — stack image over text ---- */
  @media (max-width: 980px) {
    .uniform__grid {
      grid-template-columns: 1fr;
    }

    .uniform__media {
      order: 1;
      align-self: stretch;
    }

    .uniform__text {
      order: 2;
      padding: clamp(2.5rem, 7vw, 4rem) var(--page-margin);
    }

    .uniform__list {
      max-width: none;
    }
  }

  /* ---- Breakpoint 2: mobile — tighten type ---- */
  @media (max-width: 600px) {
    .uniform__heading {
      font-size: clamp(2.2rem, 12vw, 3rem);
    }

    .uniform__desc {
      font-size: 0.95rem;
    }
  }

  /* ---- Breakpoint 3: small mobile — compact ---- */
  @media (max-width: 400px) {
    .uniform__text {
      padding: 2.25rem 1.25rem;
    }

    .uniform__heading {
      font-size: 2.1rem;
    }

    .uniform-item__summary {
      padding: 0.9rem 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Uniform",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Apparel System" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Uniform" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A coordinated everyday kit engineered for wherever you're going. Premium materials, mission-driven design, built to represent." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop the Uniform" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Flat-lay image (defaults to bundled uniform.jpg)" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Hoodie" },
        { "type": "textarea", "id": "text", "label": "Description" },
        { "type": "range", "id": "pos_x", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Hotspot X", "default": 50 },
        { "type": "range", "id": "pos_y", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Hotspot Y", "default": 50 },
        { "type": "select", "id": "label_side", "label": "Label side", "options": [{ "value": "right", "label": "Right" }, { "value": "left", "label": "Left" }], "default": "right" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Uniform" }
  ]
}
{% endschema %}
