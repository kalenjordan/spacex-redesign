<section class="hero full-width" data-section-id="{{ section.id }}">
  {% if section.settings.image != blank %}
    <img
      class="hero__bg"
      src="{{ section.settings.image | image_url: width: 2600 }}"
      alt=""
      width="2600"
      height="1600"
      loading="eager"
      fetchpriority="high"
    >
  {% else %}
    <img
      class="hero__bg"
      src="{{ 'hero.png' | asset_url }}"
      alt=""
      loading="eager"
      fetchpriority="high"
    >
  {% endif %}
  <div class="hero__scrim"></div>

  <div class="hero__inner">
    <div class="hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="hero__subheading">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary hero__cta">
          {{ section.settings.button_label }}
          <span class="btn__arrow">&rarr;</span>
        </a>
      {% endif %}
    </div>

    {% if section.settings.show_countdown %}
      <div
        class="countdown"
        data-countdown
        data-target="{{ section.settings.launch_date }}"
      >
        <span class="countdown__label">{{ section.settings.countdown_label }}</span>
        <span class="countdown__mission">{{ section.settings.launch_name }}</span>
        <span class="countdown__net">NET</span>
        <div class="countdown__clock">
          <div class="countdown__unit"><b data-days>--</b><i>Days</i></div>
          <span class="countdown__sep">:</span>
          <div class="countdown__unit"><b data-hours>--</b><i>Hrs</i></div>
          <span class="countdown__sep">:</span>
          <div class="countdown__unit"><b data-mins>--</b><i>Min</i></div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .hero {
    position: relative;
    margin-top: calc(-1 * var(--header-height));
    min-height: min(92vh, 920px);
    display: grid;
    grid-template-columns: var(--content-grid);
    align-items: end;
    overflow: hidden;
    background:
      radial-gradient(120% 80% at 80% 0%, #14233f 0%, transparent 55%),
      radial-gradient(140% 90% at 50% 120%, #0a1830 0%, transparent 60%),
      linear-gradient(180deg, #04060c 0%, #060912 100%);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(4, 6, 12, 0.85) 0%, rgba(4, 6, 12, 0.35) 45%, transparent 70%),
      linear-gradient(0deg, rgba(4, 6, 12, 0.85) 0%, transparent 40%);
  }

  .hero__inner {
    grid-column: 2;
    position: relative;
    z-index: 2;
    width: 100%;
    padding: calc(var(--header-height) + 2rem) 0 2.75rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: inherit;
  }

  .hero__content {
    max-width: 40rem;
    margin-top: auto;
  }

  .hero__eyebrow {
    margin-bottom: 1.25rem;
  }

  .hero__heading {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .hero__subheading {
    margin-top: 1.5rem;
    max-width: 30rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.05rem;
    line-height: 1.5;
  }

  .hero__cta {
    margin-top: 2rem;
  }

  /* Launch countdown */
  .countdown {
    margin-top: 3rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-heading);
  }

  .countdown__label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .countdown__mission {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .countdown__net {
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    color: var(--color-muted);
  }

  .countdown__clock {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .countdown__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 2.4rem;
  }

  .countdown__unit b {
    font-size: 1.5rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .countdown__unit i {
    margin-top: 0.35rem;
    font-style: normal;
    font-size: 0.55rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .countdown__sep {
    font-size: 1.3rem;
    color: var(--color-muted);
    line-height: 1;
  }

  @media (max-width: 749px) {
    .hero {
      align-items: end;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var roots = document.querySelectorAll('[data-countdown]');
    roots.forEach(function (root) {
      var target = new Date(root.getAttribute('data-target'));
      if (isNaN(target.getTime())) return;
      var d = root.querySelector('[data-days]');
      var h = root.querySelector('[data-hours]');
      var m = root.querySelector('[data-mins]');
      function pad(n) { return (n < 10 ? '0' : '') + n; }
      function tick() {
        var diff = Math.max(0, target.getTime() - Date.now());
        var mins = Math.floor(diff / 60000);
        d.textContent = pad(Math.floor(mins / 1440));
        h.textContent = pad(Math.floor((mins % 1440) / 60));
        m.textContent = pad(mins % 60);
      }
      tick();
      setInterval(tick, 30000);
    });
  })();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Official SpaceX Store"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wear the Mission"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium apparel. Authentic gear. Inspired by our mission to make life multiplanetary."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Trending"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Launch countdown"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show countdown",
      "default": true
    },
    {
      "type": "text",
      "id": "countdown_label",
      "label": "Label",
      "default": "Next Launch"
    },
    {
      "type": "text",
      "id": "launch_name",
      "label": "Mission name",
      "default": "Starlink 10-2"
    },
    {
      "type": "text",
      "id": "launch_date",
      "label": "Launch date/time (ISO 8601)",
      "info": "e.g. 2026-07-01T14:30:00Z",
      "default": "2026-06-17T08:00:00Z"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
