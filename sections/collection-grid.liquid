<section class="collection-grid">
  <div class="section-head">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.link_label != blank %}
      <a href="{{ section.settings.link_url }}" class="section-link">{{ section.settings.link_label }} &rsaquo;</a>
    {% endif %}
  </div>

  <div class="collection-grid__row">
    {% for block in section.blocks %}
      {%- liquid
        assign collection = block.settings.collection
        assign title = block.settings.title
        if title == blank and collection != blank
          assign title = collection.title
        endif
        assign url = '#'
        if collection != blank
          assign url = collection.url
        endif
      -%}
      <a href="{{ url }}" class="lcard" {{ block.shopify_attributes }}>
        <div class="lcard__media">
          {% if block.settings.image_asset != blank %}
            <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ title | escape }}" loading="lazy">
          {% else %}
            <div class="lcard__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          {% endif %}
          <div class="lcard__scrim"></div>
        </div>
        <div class="lcard__body">
          <h3 class="lcard__title">{{ title | default: 'Collection' }}</h3>
          <span class="lcard__cta">Shop Now &rarr;</span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .collection-grid__row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .lcard {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-foreground);
    background: var(--color-card);
  }

  .lcard__media,
  .lcard__media img,
  .lcard__scrim {
    position: absolute;
    inset: 0;
  }

  .lcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .lcard:hover .lcard__media img {
    transform: scale(1.05);
  }

  .lcard__placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .lcard__scrim {
    background: linear-gradient(0deg, rgba(4, 6, 12, 0.92) 0%, rgba(4, 6, 12, 0.15) 45%, transparent 70%);
  }

  .lcard__body {
    position: absolute;
    left: 1.1rem;
    bottom: 1.1rem;
    z-index: 2;
  }

  .lcard__title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.35rem;
  }

  .lcard__cta {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .lcard:hover .lcard__cta {
    color: var(--color-accent);
  }

  @media (max-width: 990px) {
    .collection-grid__row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .collection-grid__row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Collection" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "text", "id": "image_asset", "label": "Lifestyle image (asset filename)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Collection grid"
    }
  ]
}
{% endschema %}
