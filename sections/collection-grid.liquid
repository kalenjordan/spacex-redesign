<section class="collection-grid">
  <div class="section-head">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.link_label != blank %}
      <a href="{{ section.settings.link_url }}" class="section-link">{{ section.settings.link_label }} &rsaquo;</a>
    {% endif %}
  </div>

  <div class="collection-grid__row">
    {% for block in section.blocks %}
      {%- liquid
        assign collection = block.settings.collection
        assign title = block.settings.title
        if title == blank and collection != blank
          assign title = collection.title
        endif
        assign url = '#'
        if block.settings.link != blank
          assign url = block.settings.link
        elsif collection != blank
          assign url = collection.url
        endif
        assign image = block.settings.image
        if image == blank and collection != blank
          assign image = collection.featured_image
        endif
      -%}
      <a href="{{ url }}" class="collection-card" {{ block.shopify_attributes }}>
        <div class="collection-card__media">
          {% if image != blank %}
            <img src="{{ image | image_url: width: 600 }}" alt="{{ title | escape }}" width="600" height="760" loading="lazy">
          {% else %}
            <div class="collection-card__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          {% endif %}
          <div class="collection-card__scrim"></div>
        </div>
        <div class="collection-card__body">
          <h3 class="collection-card__title">{{ title | default: 'Collection' }}</h3>
          <span class="collection-card__cta">Shop Now &rarr;</span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .collection-grid__row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .collection-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--color-foreground);
    border-radius: 4px;
    overflow: hidden;
  }

  .collection-card__media {
    position: relative;
    aspect-ratio: 3 / 4;
    background: radial-gradient(120% 120% at 50% 10%, #161b27 0%, #0b0f18 100%);
  }

  .collection-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collection-card:hover .collection-card__media img {
    transform: scale(1.05);
  }

  .collection-card__placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .collection-card__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(4, 6, 12, 0.9) 0%, transparent 55%);
  }

  .collection-card__body {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 2;
  }

  .collection-card__title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.35rem;
  }

  .collection-card__cta {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .collection-card:hover .collection-card__cta {
    color: var(--color-accent);
  }

  @media (max-width: 990px) {
    .collection-grid__row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .collection-grid__row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Collection" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View All Collections" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Collection grid",
      "blocks": [
        { "type": "item", "settings": { "title": "Men" } },
        { "type": "item", "settings": { "title": "Women" } },
        { "type": "item", "settings": { "title": "Kids" } },
        { "type": "item", "settings": { "title": "Accessories" } },
        { "type": "item", "settings": { "title": "Flight Shirts" } }
      ]
    }
  ]
}
{% endschema %}
