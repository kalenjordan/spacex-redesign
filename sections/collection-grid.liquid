<section class="collection-grid">
  <div class="section-head">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.link_label != blank %}
      <a href="{{ section.settings.link_url }}" class="section-link">{{ section.settings.link_label }} &rsaquo;</a>
    {% endif %}
  </div>

  <div class="collection-grid__row">
    {% for block in section.blocks %}
      {%- liquid
        assign collection = block.settings.collection
        assign title = block.settings.title
        if title == blank and collection != blank
          assign title = collection.title
        endif
        assign url = '#'
        if collection != blank
          assign url = collection.url
        endif
        assign card_image = collection.featured_image
        if card_image == blank and collection != blank
          assign card_image = collection.products.first.featured_media
        endif
      -%}
      <a href="{{ url }}" class="theme-card" {{ block.shopify_attributes }}>
        <div class="theme-card__media">
          {% if card_image != blank %}
            <img src="{{ card_image | image_url: width: 600 }}" alt="{{ title | escape }}" loading="lazy">
          {% else %}
            <div class="theme-card__placeholder">{{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          {% endif %}
        </div>
        <div class="theme-card__body">
          <h3 class="theme-card__title">{{ title | default: 'Collection' }}</h3>
          <span class="theme-card__cta">Shop Now &rarr;</span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .collection-grid__row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .theme-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-foreground);
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }

  .theme-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-3px);
  }

  .theme-card__media {
    aspect-ratio: 1 / 1;
    background: radial-gradient(120% 120% at 50% 22%, #161d2c 0%, #0a0e16 100%);
  }

  .theme-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 9%;
    transition: transform 0.4s ease;
  }

  .theme-card:hover .theme-card__media img {
    transform: scale(1.05);
  }

  .theme-card__placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .theme-card__body {
    padding: 1rem 1.1rem 1.25rem;
  }

  .theme-card__title {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.35rem;
  }

  .theme-card__cta {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .theme-card:hover .theme-card__cta {
    color: var(--color-accent);
  }

  @media (max-width: 990px) {
    .collection-grid__row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .collection-grid__row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Theme grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Mission" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Theme",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title override" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Theme grid"
    }
  ]
}
{% endschema %}
