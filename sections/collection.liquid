{% comment %}
  Collection page — styled product grid using the shared product card.
{% endcomment %}

<div class="collection-page">
  <header class="collection-page__head">
    <p class="eyebrow">{{ 'general.collection' | t | default: 'Collection' }}</p>
    <h1 class="collection-page__title">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div class="collection-page__desc">{{ collection.description }}</div>
    {% endif %}
    <p class="collection-page__count">{{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}</p>
  </header>

  {% paginate collection.products by 24 %}
    {% if collection.products.size > 0 %}
      <div class="collection-page__grid">
        {% for product in collection.products %}
          {% render 'product-card', product: product, placeholder_index: forloop.index %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="collection-page__pagination">{{ paginate | default_pagination }}</nav>
      {% endif %}
    {% else %}
      <p class="collection-page__empty">No products in this collection yet.</p>
    {% endif %}
  {% endpaginate %}
</div>

{% stylesheet %}
  .collection-page {
    padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .collection-page__head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .collection-page__title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 0.75rem 0 0;
  }

  .collection-page__desc {
    color: var(--color-muted);
    max-width: 42rem;
    line-height: 1.6;
    margin-top: 1rem;
  }

  .collection-page__count {
    color: var(--color-muted);
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-top: 1rem;
  }

  .collection-page__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .collection-page__empty {
    color: var(--color-muted);
  }

  .collection-page__pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 3rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
  }

  .collection-page__pagination a,
  .collection-page__pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.4rem;
    height: 2.4rem;
    padding: 0 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-foreground);
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }

  .collection-page__pagination a:hover {
    border-color: var(--color-border-strong);
  }

  .collection-page__pagination .current {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 990px) {
    .collection-page__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 740px) {
    .collection-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.85rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
