{%- liquid
  assign handle_string = section.settings.product_handles | strip
  assign use_handles = false
  if handle_string != blank
    assign use_handles = true
    assign handle_list = handle_string | split: ','
  else
    assign products = section.settings.collection.products
    if section.settings.collection == blank or products.size == 0
      assign products = collections.all.products
    endif
    assign count = products.size
  endif
-%}

<section class="carousel" data-carousel>
  <div class="section-head">
    <div>
      {% if section.settings.eyebrow != blank %}
        <p class="section-eyebrow text-muted">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="carousel__controls">
      {% if section.settings.link_label != blank %}
        <a href="{{ section.settings.link_url }}" class="section-link">{{ section.settings.link_label }} &rsaquo;</a>
      {% endif %}
      <button class="carousel__arrow" data-carousel-next aria-label="Next">&rarr;</button>
    </div>
  </div>

  <div class="carousel__track" data-carousel-track>
    {% if use_handles %}
      {% for h in handle_list %}
        {% assign card_handle = h | strip %}
        {% assign product = all_products[card_handle] %}
        {% if product != blank and product.id %}
          {% render 'product-card', product: product, placeholder_index: forloop.index, force_badge: section.settings.force_badge, cutout: true %}
        {% endif %}
      {% endfor %}
    {% elsif count > 0 %}
      {% for product in products limit: section.settings.max_products %}
        {% render 'product-card', product: product, placeholder_index: forloop.index, force_badge: section.settings.force_badge %}
      {% endfor %}
    {% else %}
      {% for i in (1..5) %}
        {% render 'product-card', placeholder_index: i, force_badge: section.settings.force_badge %}
      {% endfor %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .carousel {
    width: 100%;
  }

  .carousel__controls {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .carousel__arrow {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border-strong);
    background: transparent;
    color: var(--color-foreground);
    font-size: 1rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .carousel__arrow:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(15.5rem, 1fr);
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }

  .carousel__track::-webkit-scrollbar {
    display: none;
  }

  /* Product card */
  .product-card {
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-foreground);
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }

  .product-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-3px);
  }

  .product-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: linear-gradient(180deg, #f5f6f8 0%, #e9ebf0 100%);
  }

  /* Cutout cards sit on a dark surface with transparent product PNGs */
  .product-card--cut .product-card__media {
    background: radial-gradient(120% 120% at 50% 22%, #161d2c 0%, #0a0e16 100%);
  }

  .product-card--cut .product-card__img {
    padding: 9%;
  }

  .product-card__badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 2;
  }

  .product-card__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 7%;
  }

  .product-card__img--placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.25;
  }

  .product-card__body {
    padding: 1.1rem 1.15rem 1.35rem;
  }

  .product-card__swatches {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
  }

  .swatch {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--color-border-strong);
  }

  .product-card__title {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.3rem;
  }

  .product-card__meta {
    color: var(--color-muted);
    font-size: 0.78rem;
    margin: 0 0 0.75rem;
  }

  .product-card__price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0;
  }
{% endstylesheet %}

<script>
  (function () {
    document.querySelectorAll('[data-carousel]').forEach(function (root) {
      var track = root.querySelector('[data-carousel-track]');
      var next = root.querySelector('[data-carousel-next]');
      if (!track || !next) return;
      next.addEventListener('click', function () {
        var card = track.querySelector('.product-card');
        var step = card ? card.offsetWidth + 20 : 300;
        var atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10;
        track.scrollBy({ left: atEnd ? -track.scrollWidth : step * 2, behavior: 'smooth' });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product carousel",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Now"
    },
    {
      "type": "textarea",
      "id": "product_handles",
      "label": "Product handles (comma-separated)",
      "info": "Hard-coded product list. Overrides the collection when set."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "Max products",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "force_badge",
      "label": "Show NEW badge on all cards",
      "default": false
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Product carousel"
    }
  ]
}
{% endschema %}
