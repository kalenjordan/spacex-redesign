{% comment %}
  Renders a product card.
  Accepts:
  - product: {Product} product object (optional — placeholder shown when blank)
  - placeholder_index: {Number} index used to vary placeholder art
{% endcomment %}

{%- liquid
  assign is_new = false
  if product != blank and product.tags contains 'new'
    assign is_new = true
  endif
  if force_badge
    assign is_new = true
  endif
  assign ph = placeholder_index | modulo: 4 | plus: 1
-%}

<a class="product-card{% if cutout %} product-card--cut{% endif %}" {% if product != blank %}href="{{ product.url }}"{% else %}href="#"{% endif %}>
  <div class="product-card__media">
    {% if is_new %}<span class="badge product-card__badge">New</span>{% endif %}

    {% if cutout and product != blank %}
      <img
        class="product-card__img"
        src="{{ 'cut-' | append: product.handle | append: '.png' | asset_url }}"
        alt="{{ product.title | escape }}"
        loading="lazy"
      >
    {% elsif product != blank and product.featured_media %}
      <img
        class="product-card__img"
        src="{{ product.featured_media | image_url: width: 700 }}"
        alt="{{ product.featured_media.alt | escape }}"
        width="700"
        height="700"
        loading="lazy"
      >
    {% else %}
      <div class="product-card__img product-card__img--placeholder">
        {{ 'product-apparel-' | append: ph | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {% endif %}
  </div>

  <div class="product-card__body">
    {%- if product != blank -%}
      {%- assign color_option = null -%}
      {%- for option in product.options_with_values -%}
        {%- if option.name contains 'Color' or option.name contains 'Colour' -%}
          {%- assign color_option = option -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if color_option -%}
        <div class="product-card__swatches">
          {%- for value in color_option.values limit: 6 -%}
            <span class="swatch" style="background: {{ value | downcase | replace: ' ', '' }};" title="{{ value }}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="product-card__swatches">
        <span class="swatch" style="background:#111;"></span>
        <span class="swatch" style="background:#3a3a3a;"></span>
        <span class="swatch" style="background:#6b6b6b;"></span>
      </div>
    {%- endif -%}

    <h3 class="product-card__title">
      {% if product != blank %}{{ product.title }}{% else %}SpaceX Gear{% endif %}
    </h3>
    <p class="product-card__meta">
      {% if product != blank and product.type != blank %}{{ product.type }}{% else %}Premium Collection{% endif %}
    </p>
    <p class="product-card__price">
      {% if product != blank %}{{ product.price | money }}{% else %}$34.00{% endif %}
    </p>
  </div>
</a>
