{% comment %}
  Renders a product card with the title + price overlaid on the image.
  Accepts:
  - product: {Product} product object (optional — placeholder shown when blank)
  - placeholder_index: {Number} index used to vary placeholder art
  - force_badge: {Boolean} force the NEW badge
{% endcomment %}

{%- liquid
  assign is_new = false
  if product != blank and product.tags contains 'new'
    assign is_new = true
  endif
  if force_badge
    assign is_new = true
  endif
  assign ph = placeholder_index | modulo: 4 | plus: 1
-%}

<a class="product-card" {% if product != blank %}href="{{ product.url }}"{% else %}href="#"{% endif %}>
  {% if is_new %}<span class="badge product-card__badge">New</span>{% endif %}

  <div class="product-card__media">
    {% if product != blank and product.featured_media %}
      <img
        class="product-card__img"
        src="{{ product.featured_media | image_url: width: 700 }}"
        alt="{{ product.featured_media.alt | escape }}"
        width="700"
        height="700"
        loading="lazy"
      >
    {% else %}
      <div class="product-card__img product-card__img--placeholder">
        {{ 'product-apparel-' | append: ph | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {% endif %}
  </div>

  <div class="product-card__scrim"></div>

  <div class="product-card__overlay">
    <h3 class="product-card__title">
      {% if product != blank %}{{ product.title }}{% else %}SpaceX Gear{% endif %}
    </h3>
    <p class="product-card__price">
      {% if product != blank %}{{ product.price | money }}{% else %}$34.00{% endif %}
    </p>
  </div>
</a>
